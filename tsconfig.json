{
	"compilerOptions": {
		"target": "ES2020",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"lib": ["ES2020", "DOM"],
		"outDir": "./dist",
		"strict": true,
		"skipLibCheck": true,
		"types": ["firefox-webext-browser", "bun"]
	},
	"include": ["src/**/*", "build.ts"],
	"exclude": ["src/__tests__", "node_modules"]
}
