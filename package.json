{
	"name": "auto-refresh",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "bun run build.ts",
		"build:prod": "NODE_ENV=production bun run build.ts",
		"build:sourcemaps": "SOURCE_MAPS=true bun run build.ts",
		"dev": "bun --watch run build.ts",
		"typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.build.json",
		"test": "bun test",
		"version:bump": "bun scripts/version-bump.ts",
		"release": "bun scripts/release.ts",
		"lint": "bunx biome lint ./src",
		"format": "bunx biome format --write ./src",
		"check": "bunx biome check ./src"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@types/bun": "^1.3.13",
		"@types/firefox-webext-browser": "^143.0.0",
		"web-ext": "^8.3.0"
	},
	"peerDependencies": {
		"typescript": "^6.0.3"
	},
	"version": "1.3.3"
}
